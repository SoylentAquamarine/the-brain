# .env.example — Copy this to .env and fill in your API keys.
#
# NEVER commit .env to git — it is listed in .gitignore.
# Sign-up links for free-tier keys are in config/models.yaml.

# ── Required: Claude orchestrator ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6     # optional override

# ── Already have: OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini              # optional override

# ── Already have: Google Gemini ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash         # optional override

# ── Free tier: Groq (sign up at console.groq.com) ─────────────────────────
GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama3-8b-8192             # optional override

# ── Free tier: Cohere (sign up at dashboard.cohere.com) ───────────────────
COHERE_API_KEY=your_cohere_key_here
# COHERE_MODEL=command-r                # optional override

# ── Routing behaviour ─────────────────────────────────────────────────────
# BRAIN_DYNAMIC_ROUTING=1   # Uncomment to enable Claude-assisted routing
                             # (costs ~100 tokens per call but smarter routing)
